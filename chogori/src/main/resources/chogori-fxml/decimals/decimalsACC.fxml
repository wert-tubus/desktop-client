<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox prefHeight="300.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.wert.tubus.chogori.entities.decimals.Decimal_ACCController">
   <children>
      <VBox>
         <children>
              <Label text="Децимальный номер (6 цифр) :">
                  <font>
                      <Font size="14.0" />
                  </font>
               <VBox.margin>
                  <Insets left="10.0" top="5.0" />
               </VBox.margin>
              </Label>
              <TextField fx:id="tfName" prefHeight="25.0" GridPane.columnIndex="1">
                  <GridPane.margin>
                      <Insets right="10.0" />
                  </GridPane.margin>
                  <font>
                      <Font size="14.0" />
                  </font>
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
              </TextField>
         </children>
      </VBox>
      <VBox VBox.vgrow="ALWAYS">
         <children>
      
                          <Label text="Описание :">
                  <font>
                      <Font size="14.0" />
                  </font>
               <VBox.margin>
                  <Insets left="10.0" />
               </VBox.margin>
              </Label>
              <TextArea fx:id="taDescription" maxHeight="1.7976931348623157E308" prefHeight="101.0" prefWidth="280.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" VBox.vgrow="ALWAYS">
                  <GridPane.margin>
                      <Insets bottom="5.0" right="10.0" top="10.0" />
                  </GridPane.margin>
               <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
              </TextArea>
         </children>
      </VBox>
      <HBox alignment="CENTER_RIGHT">
         <children>
      
                                      <Label text="Начальный номер :">
                  <font>
                      <Font size="14.0" />
                  </font>
              </Label>
              <TextField fx:id="tfInitialNumber" prefHeight="30.0" prefWidth="105.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                  <GridPane.margin>
                      <Insets right="10.0" />
                  </GridPane.margin>
                  <font>
                      <Font size="14.0" />
                  </font>
               <HBox.margin>
                  <Insets bottom="5.0" left="5.0" right="10.0" top="5.0" />
               </HBox.margin>
              </TextField>
         </children>
      </HBox>

              <StackPane fx:id="stackPaneForButtons">
            <children>
                <HBox alignment="CENTER_RIGHT" spacing="10.0" StackPane.alignment="CENTER_RIGHT">
                    <children>
                        <StackPane fx:id="spIndicator" maxHeight="39.0" maxWidth="39.0" minHeight="39.0" minWidth="39.0" prefHeight="39.0" prefWidth="39.0" />
                        <Button fx:id="btnCancel" cancelButton="true" minWidth="-Infinity" mnemonicParsing="false" onAction="#cancel" prefHeight="39.0" prefWidth="102.0" text="ОТМЕНА">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" top="5.0" />
                     </HBox.margin>
                        </Button>
                        <Button fx:id="btnOk" defaultButton="true" minWidth="-Infinity" mnemonicParsing="false" onAction="#ok" prefHeight="39.0" prefWidth="102.0" text="ОК">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                     <HBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                     </HBox.margin>
                        </Button>
                    </children>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </HBox>
            </children>
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" top="5.0" />
         </VBox.margin>
        </StackPane>
   </children>
</VBox>
