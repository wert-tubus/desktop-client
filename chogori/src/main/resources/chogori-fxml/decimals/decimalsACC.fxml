<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane fx:id="modal_pane" prefHeight="250.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.wert.tubus.chogori.entities.decimals.Decimal_ACCController">
    <columnConstraints>
        <ColumnConstraints fx:id="column" hgrow="SOMETIMES" maxWidth="372.0" minWidth="10.0" prefWidth="120.0" />
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="389.0" minWidth="10.0" prefWidth="330.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints maxHeight="45.0" minHeight="45.0" prefHeight="45.0" vgrow="SOMETIMES" />
        <RowConstraints maxHeight="61.0" minHeight="45.0" prefHeight="61.0" vgrow="SOMETIMES" />
        <RowConstraints maxHeight="45.0" minHeight="45.0" prefHeight="45.0" vgrow="SOMETIMES" />
        <RowConstraints maxHeight="45.0" minHeight="45.0" prefHeight="45.0" vgrow="SOMETIMES" />
        <RowConstraints maxHeight="50.0" minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
    </rowConstraints>
    <children>
        <Label text="Наименование :">
            <GridPane.margin>
                <Insets left="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="tfName" prefHeight="25.0" GridPane.columnIndex="1">
            <GridPane.margin>
                <Insets right="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </TextField>

        <Label text="Описание :" GridPane.rowIndex="1">
            <padding>
                <Insets left="10.0" />
            </padding>
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextArea fx:id="taDescription" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <GridPane.margin>
                <Insets bottom="5.0" right="10.0" top="10.0" />
            </GridPane.margin>
        </TextArea>

        <Label text="Начальный номер :" GridPane.rowIndex="2">
            <GridPane.margin>
                <Insets left="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="tfInitialNumber" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <GridPane.margin>
                <Insets right="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </TextField>

        <Label text="Конечный номер :" GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets left="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="tfLastNumber" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <GridPane.margin>
                <Insets right="10.0" />
            </GridPane.margin>
            <font>
                <Font size="14.0" />
            </font>
        </TextField>

        <StackPane fx:id="stackPaneForButtons" prefHeight="150.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <children>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <StackPane fx:id="spIndicator" maxHeight="39.0" maxWidth="39.0" minHeight="39.0" minWidth="39.0" prefHeight="39.0" prefWidth="39.0" />
                        <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" onAction="#cancel" prefHeight="39.0" prefWidth="126.0" text="ОТМЕНА">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnOk" defaultButton="true" mnemonicParsing="false" onAction="#ok" prefHeight="39.0" prefWidth="132.0" text="ОК">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                    </children>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </HBox>
            </children>
        </StackPane>
    </children>
</GridPane>
