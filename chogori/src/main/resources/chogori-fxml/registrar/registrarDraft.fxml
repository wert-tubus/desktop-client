<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.wert.tubus.chogori.registration.RegistrarDraftController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <Label text="Создание нового паспорта">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <Separator />

                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" maxWidth="150.0" minWidth="100.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <children>
                        <Label text="Номер (временный):" />
                        <TextField fx:id="tfNumber" editable="false" GridPane.columnIndex="1" />

                        <Label text="Наименование:" GridPane.rowIndex="1" />
                        <TextField fx:id="tfName" promptText="Введите наименование" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Изделие:" GridPane.rowIndex="2" />
                        <TextArea fx:id="taProduct" prefHeight="80.0" promptText="Введите информацию об изделии" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Разработчик:" GridPane.rowIndex="3" />
                        <TextField fx:id="tfDeveloper" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Дата:" GridPane.rowIndex="4" />
                        <TextField fx:id="tfDate" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>

                <Separator />

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnAccept" mnemonicParsing="false" text="Принять" />
                        <Button fx:id="btnCancel" mnemonicParsing="false" text="Отмена" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
