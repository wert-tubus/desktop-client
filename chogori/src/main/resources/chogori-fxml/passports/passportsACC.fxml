<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxWidth="-Infinity" minWidth="-Infinity" prefWidth="350.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.wert.tubus.chogori.entities.passports.Passport_ACCController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <VBox maxWidth="1.7976931348623157E308">
                    <children>
                        <Label text="Децимальный номер:">
                            <VBox.margin>
                                <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                            </VBox.margin>
                        </Label>
                        <TextField fx:id="tfNumber" editable="false" maxWidth="1.7976931348623157E308">
                     <font>
                        <Font size="14.0" />
                     </font></TextField>
                    </children>
                </VBox>
                <VBox maxWidth="1.7976931348623157E308">
                    <children>
                        <Label text="Наименование:">
                            <VBox.margin>
                                <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                            </VBox.margin>
                        </Label>
                        <TextField fx:id="tfName" maxWidth="1.7976931348623157E308" promptText="Введите наименование">
                     <font>
                        <Font size="14.0" />
                     </font></TextField>
                    </children>
                </VBox>
                <VBox maxWidth="1.7976931348623157E308">
                    <children>
                        <Label text="Изделие:">
                            <VBox.margin>
                                <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                            </VBox.margin>
                        </Label>
                        <TextArea fx:id="taProduct" maxWidth="1.7976931348623157E308" prefHeight="80.0" promptText="Введите информацию об изделии">
                     <font>
                        <Font size="14.0" />
                     </font></TextArea>
                    </children>
                </VBox>
                <HBox maxWidth="1.7976931348623157E308" spacing="10.0">
                    <children>
                        <VBox maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Разработчик:">
                                    <VBox.margin>
                                        <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                                    </VBox.margin>
                                </Label>
                        <ComboBox fx:id="bxUser" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>
                        <VBox>
                            <children>
                                <Label text="Дата:">
                                    <VBox.margin>
                                        <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                                    </VBox.margin>
                                </Label>
                                <TextField fx:id="tfDate" alignment="CENTER" editable="false" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="100.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator />

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <StackPane fx:id="spIndicator" maxHeight="39.0" maxWidth="39.0" minHeight="39.0" minWidth="39.0" prefHeight="39.0" prefWidth="39.0" />
                        <Button fx:id="btnCancel" cancelButton="true" minWidth="-Infinity" mnemonicParsing="false" onAction="#cancel" prefHeight="39.0" prefWidth="102.0" text="ОТМЕНА">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnOk" defaultButton="true" minWidth="-Infinity" mnemonicParsing="false" onAction="#ok" prefHeight="39.0" prefWidth="102.0" text="ОК">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
